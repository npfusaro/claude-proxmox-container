#!/usr/bin/env bash
# core.func - minimal shared helpers for the claude-proxmox-container scripts.
# Distilled from the community-scripts.org (Proxmox VE Helper-Scripts) conventions
# so both the host orchestrator and the in-container installer share one look & feel.
# Safe to source more than once.

[[ -n "${__CORE_FUNC_SOURCED:-}" ]] && return 0
__CORE_FUNC_SOURCED=1

# ---------------------------------------------------------------------------
# Colors / symbols (disabled automatically when stdout is not a terminal)
# ---------------------------------------------------------------------------
if [[ -t 1 ]]; then
  RD=$'\033[01;31m'
  GN=$'\033[1;92m'
  YW=$'\033[33m'
  BL=$'\033[36m'
  CL=$'\033[m'
else
  RD=''; GN=''; YW=''; BL=''; CL=''
fi

CM="${GN}✓${CL}"
CROSS="${RD}✗${CL}"
INFO="${BL}ℹ${CL}"
WARN="${YW}⚠${CL}"

# ---------------------------------------------------------------------------
# Spinner-aware status messages.
# A spinner only runs on an interactive terminal; under `pct exec` (no TTY)
# the functions fall back to plain, log-friendly lines.
# ---------------------------------------------------------------------------
SPINNER_PID=""

_stop_spinner() {
  if [[ -n "$SPINNER_PID" ]] && kill -0 "$SPINNER_PID" 2>/dev/null; then
    kill "$SPINNER_PID" 2>/dev/null
    wait "$SPINNER_PID" 2>/dev/null
    printf "\r\033[K"
  fi
  SPINNER_PID=""
}

msg_info() {
  local msg="$1"
  _stop_spinner
  if [[ -t 2 ]]; then
    local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    (
      while true; do
        for ((i = 0; i < ${#frames}; i++)); do
          printf "\r${BL}%s${CL} %s" "${frames:$i:1}" "$msg" >&2
          sleep 0.1
        done
      done
    ) &
    SPINNER_PID=$!
    disown "$SPINNER_PID" 2>/dev/null || true
  else
    printf "%s %s\n" "$INFO" "$msg" >&2
  fi
}

msg_ok() {
  _stop_spinner
  printf "%s %s\n" "$CM" "$1" >&2
}

msg_error() {
  _stop_spinner
  printf "%s %s\n" "$CROSS" "$1" >&2
}

msg_warn() {
  _stop_spinner
  printf "%s %s\n" "$WARN" "$1" >&2
}

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------
header_info() {
  local title="${1:-Claude Code}"
  clear 2>/dev/null || true
  cat <<EOF
${BL}
   ____ _                 _         ____          _
  / ___| | __ _ _   _  __| | ___   / ___|___   __| | ___
 | |   | |/ _\` | | | |/ _\` |/ _ \\ | |   / _ \\ / _\` |/ _ \\
 | |___| | (_| | |_| | (_| |  __/ | |__| (_) | (_| |  __/
  \\____|_|\\__,_|\\__,_|\\__,_|\\___|  \\____\\___/ \\__,_|\\___|
${CL}
  ${title} - Proxmox LXC remote dev container
EOF
}

# ---------------------------------------------------------------------------
# Error handling
# ---------------------------------------------------------------------------
error_handler() {
  local exit_code=$?
  local line_no=${1:-?}
  local command=${2:-?}
  _stop_spinner
  printf "\n%s Error on line %s (exit %s): %s\n" "$CROSS" "$line_no" "$exit_code" "$command" >&2
  exit "$exit_code"
}

catch_errors() {
  set -Eeuo pipefail
  trap '_stop_spinner' EXIT
  trap 'error_handler "$LINENO" "$BASH_COMMAND"' ERR
}
